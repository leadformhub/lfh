{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/daily-users-report",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-feedback-report",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/expire-plans",
      "schedule": "10 8 * * *"
    },
    {
      "path": "/api/cron/send-expiry-reminders",
      "schedule": "20 8 * * *"
    },
    {
      "path": "/api/support-requests/auto-close",
      "schedule": "30 8 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.leadformhub.com" }],
      "destination": "https://leadformhub.com/",
      "permanent": true
    },
    {
      "source": "/blog",
      "has": [{ "type": "host", "value": "www.leadformhub.com" }],
      "destination": "https://leadformhub.com/blog",
      "permanent": true
    },
    {
      "source": "/blog/",
      "has": [{ "type": "host", "value": "www.leadformhub.com" }],
      "destination": "https://leadformhub.com/blog",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.leadformhub.com" }],
      "destination": "https://leadformhub.com/:path*",
      "permanent": true
    }
  ]
}
