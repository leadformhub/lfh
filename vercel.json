{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/daily-users-report",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/daily-feedback-report",
